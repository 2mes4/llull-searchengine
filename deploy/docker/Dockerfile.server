FROM golang:1.25-alpine AS builder

ENV GOTOOLCHAIN=local
ENV GOPROXY=direct

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /llull ./cmd/server

FROM alpine:3.19

RUN apk --no-cache add ca-certificates curl
COPY --from=builder /llull /usr/local/bin/llull

EXPOSE 8080

HEALTHCHECK --interval=5s --timeout=3s --retries=3 \
  CMD curl -f http://localhost:8080/v1/health || exit 1

ENTRYPOINT ["llull"]
